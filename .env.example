# Twitter / X account (used by twikit to scrape)
TWITTER_USERNAME=your_twitter_username
TWITTER_EMAIL=your_twitter_email@gmail.com
TWITTER_PASSWORD=your_twitter_password

# Groq (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key

# X API keys (free tier — for posting only)
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_SECRET=your_x_access_secret

# Your niche / voice (the agent writes in this style)
BRAND_VOICE=bold, direct, no fluff, slightly contrarian
NICHE=AI automation and making money online
